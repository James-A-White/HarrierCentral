{
  "schema": "HC6",
  "name": "hcportal_getEvent",
  "version": "1.2.0",
  "description": "Retrieves event details by publicEventId, kennelUniqueShortName + runDesignator, or special keywords 'nextrun'/'lastrun'. Returns an EventDetails rowset (always) and optionally an AttendeeList rowset. AttendeeList is suppressed for service account callers (GUIDs 11111111-... and 22222222-...). @includePaymentInfo controls whether the AttendeeList includes full payment columns. Auth is enforced via HC6.ValidatePortalAuth. Used by both admin portal and public HashRuns.org site.",
  "parameters": [
    {
      "name": "deviceId",
      "type": "UNIQUEIDENTIFIER",
      "nullable": true,
      "mapsToColumn": "Device.id",
      "description": "Auth: device ID used to look up the authenticated user and device secret. Validated via HC6.ValidatePortalAuth."
    },
    {
      "name": "accessToken",
      "type": "NVARCHAR(1000)",
      "nullable": true,
      "mapsToColumn": null,
      "description": "Auth: short-lived cryptographic token, validated via HC6.ValidatePortalAuth. Token validation is now enforced (was commented out in HC5)."
    },
    {
      "name": "includePaymentInfo",
      "type": "INT",
      "nullable": false,
      "mapsToColumn": null,
      "description": "Controls AttendeeList shape: 0 = basic attendee columns (no payment amounts), 1 = full payment details (amounts, confirmation dates, payment types). Only relevant when caller is not a service account."
    },
    {
      "name": "publicEventId",
      "type": "UNIQUEIDENTIFIER",
      "nullable": true,
      "mapsToColumn": "Event.PublicEventId",
      "description": "Optional: direct event lookup by public ID. Takes precedence over kennelUniqueShortName/runDesignator when provided. Validation is now enforced (was commented out in HC5)."
    },
    {
      "name": "kennelUniqueShortName",
      "type": "NVARCHAR(50)",
      "nullable": true,
      "mapsToColumn": "Kennel.KennelUniqueShortName",
      "description": "Optional: kennel identifier used with @runDesignator to resolve the event indirectly."
    },
    {
      "name": "runDesignator",
      "type": "NVARCHAR(50)",
      "nullable": true,
      "mapsToColumn": null,
      "description": "Optional: event identifier within a kennel. Special values: 'nextrun' (next future event, >4 hours from now in kennel local time), 'lastrun' (most recent past event using same threshold). Any other value is treated as EventNumber cast to NVARCHAR(50) for exact match."
    }
  ],
  "rowsets": [
    {
      "index": 0,
      "name": "ErrorEnvelope",
      "description": "Returned on any validation, auth, or runtime error. Short-circuits on first error.",
      "columns": [
        { "name": "Success", "type": "INT", "nullable": false, "description": "Always 0 on error" },
        { "name": "ErrorMessage", "type": "NVARCHAR(255)", "nullable": true, "description": "Human-readable error message" }
      ]
    },
    {
      "index": 0,
      "name": "EventDetails",
      "description": "Returned when the event is found. Single row with comprehensive event, kennel, location, pricing, dissemination, integration, and currency data.",
      "columns": [
        { "name": "publicEventId", "type": "UNIQUEIDENTIFIER", "nullable": false, "description": "Event.PublicEventId" },
        { "name": "publicKennelId", "type": "UNIQUEIDENTIFIER", "nullable": false, "description": "Kennel.PublicKennelId" },
        { "name": "kennelName", "type": "NVARCHAR(250)", "nullable": true, "description": "Kennel.KennelName" },
        { "name": "kennelLogo", "type": "NVARCHAR(500)", "nullable": true, "description": "Kennel.KennelLogo" },
        { "name": "kennelWebUrl", "type": "NVARCHAR(500)", "nullable": true, "description": "Kennel.KennelWebsiteUrl" },
        { "name": "kennelShortName", "type": "NVARCHAR(25)", "nullable": true, "description": "Kennel.KennelShortName" },
        { "name": "kennelUniqueShortName", "type": "NVARCHAR(50)", "nullable": true, "description": "Kennel.KennelUniqueShortName" },
        { "name": "isVisible", "type": "SMALLINT", "nullable": false, "description": "Event.IsVisible" },
        { "name": "isCountedRun", "type": "SMALLINT", "nullable": false, "description": "Event.IsCountedRun" },
        { "name": "eventGeographicScope", "type": "SMALLINT", "nullable": false, "description": "Event.EventGeographicScope (1=Normal, 2=Local special, 3=Regional, 4=National, 5=Continental, 6=Global, 7=Other)" },
        { "name": "isPromotedEvent", "type": "SMALLINT", "nullable": false, "description": "Event.IsPromotedEvent" },
        { "name": "eventNumber", "type": "SMALLINT", "nullable": true, "description": "Event.EventNumber — sequential run number within kennel" },
        { "name": "eventPriceForMembers", "type": "DECIMAL(10,4)", "nullable": true, "description": "Event.EventPriceForMembers" },
        { "name": "eventPriceForNonMembers", "type": "DECIMAL(10,4)", "nullable": true, "description": "Event.EventPriceForNonMembers" },
        { "name": "kennelDefaultEventPriceForMembers", "type": "DECIMAL(10,4)", "nullable": true, "description": "Kennel.DefaultEventPriceForMembers" },
        { "name": "kennelDefaultEventPriceForNonMembers", "type": "DECIMAL(10,4)", "nullable": true, "description": "Kennel.DefaultEventPriceForNonMembers" },
        { "name": "eventPriceForExtras", "type": "DECIMAL(10,4)", "nullable": true, "description": "Event.EventPriceForExtras" },
        { "name": "extrasDescription", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.ExtrasDescription" },
        { "name": "extrasRsvpRequired", "type": "SMALLINT", "nullable": true, "description": "Event.ExtrasRsvpRequired" },
        { "name": "doTrackHashCash", "type": "SMALLINT", "nullable": true, "description": "Event.DoTrackHashCash" },
        { "name": "kenDisseminateHashRunsDotOrg", "type": "SMALLINT", "nullable": true, "description": "Kennel.DisseminateHashRunsDotOrg" },
        { "name": "kenDisseminateAllowWebLinks", "type": "SMALLINT", "nullable": true, "description": "Kennel.DisseminateAllowWebLinks" },
        { "name": "kenDisseminationAudience", "type": "INT", "nullable": true, "description": "Kennel.DisseminationAudience" },
        { "name": "evtDisseminationAudience", "type": "INT", "nullable": true, "description": "Event.EvtDisseminationAudience" },
        { "name": "evtDisseminateAllowWebLinks", "type": "SMALLINT", "nullable": true, "description": "Event.EvtDisseminateAllowWebLinks" },
        { "name": "evtDisseminateHashRunsDotOrg", "type": "SMALLINT", "nullable": true, "description": "Event.EvtDisseminateHashRunsDotOrg" },
        { "name": "evtPublishToGoogleCalendar", "type": "SMALLINT", "nullable": true, "description": "Event.PublishToGoogleCalendar" },
        { "name": "kenPublishToGoogleCalendar", "type": "SMALLINT", "nullable": true, "description": "Kennel.PublishToGoogleCalendar" },
        { "name": "evtPublishToGoogleCalendarAddresses", "type": "NVARCHAR(1000)", "nullable": true, "description": "Event.PublishToGoogleCalendarAddresses" },
        { "name": "evtDisseminateOnGlobalGoogleCalendar", "type": "SMALLINT", "nullable": true, "description": "Event.DisseminateOnGlobalGoogleCalendar" },
        { "name": "kenDisseminateOnGlobalGoogleCalendar", "type": "SMALLINT", "nullable": true, "description": "Kennel.DisseminateOnGlobalGoogleCalendar" },
        { "name": "inboundIntegrationId", "type": "INT", "nullable": true, "description": "Event.InboundIntegrationId" },
        { "name": "integrationEnabled", "type": "INT", "nullable": true, "description": "Event.IntegrationEnabled" },
        { "name": "extDataLastUpdated", "type": "DATETIMEOFFSET(7)", "nullable": true, "description": "Event.FacebookRecordLastUpdated — aliased as extDataLastUpdated" },
        { "name": "eventFacebookId", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.EventFacebookId" },
        { "name": "absoluteEventNumber", "type": "SMALLINT", "nullable": true, "description": "Event.AbsoluteEventNumber" },
        { "name": "canEditRunAttendence", "type": "SMALLINT", "nullable": true, "description": "Event.CanEditRunAttendence" },
        { "name": "hares", "type": "NVARCHAR(2500)", "nullable": true, "description": "Event.Hares" },
        { "name": "eventPaymentScheme", "type": "NVARCHAR(10)", "nullable": true, "description": "Event.EventPaymentScheme" },
        { "name": "eventPaymentUrl", "type": "NVARCHAR(2000)", "nullable": true, "description": "Event.EventPaymentUrl" },
        { "name": "eventPaymentUrlExpires", "type": "DATETIMEOFFSET(7)", "nullable": true, "description": "Event.EventPaymentUrlExpires" },
        { "name": "unconfirmedBankXferCount", "type": "INT", "nullable": true, "description": "Event.UnconfirmedBankXferCount" },
        { "name": "tags1", "type": "INT", "nullable": true, "description": "Event.Tags1 — event tag bitfield 1" },
        { "name": "tags2", "type": "INT", "nullable": true, "description": "Event.Tags2 — event tag bitfield 2" },
        { "name": "tags3", "type": "INT", "nullable": true, "description": "Event.Tags3 — event tag bitfield 3" },
        { "name": "extEventImage", "type": "NVARCHAR(500)", "nullable": true, "description": "Event.FbEventImage — raw external (Facebook) event image URL, returned separately from eventImage so callers can implement their own UseFbImage logic" },
        { "name": "eventImage", "type": "NVARCHAR(500)", "nullable": true, "description": "Event.EventImage — HC-managed event image URL" },
        { "name": "extEventName", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.FbEventName — raw external event name" },
        { "name": "eventName", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.EventName — HC-managed event name" },
        { "name": "extEventStartDatetime", "type": "DATETIME2", "nullable": true, "description": "Event.FbEventStartDatetime converted to DATETIME2 (local time; DATETIMEOFFSET timezone migration is a known TODO)" },
        { "name": "eventStartDatetime", "type": "DATETIME2", "nullable": true, "description": "Event.EventStartDatetime converted to DATETIME2 (local time; DATETIMEOFFSET timezone migration is a known TODO)" },
        { "name": "eventEndDatetime", "type": "DATETIME2", "nullable": true, "description": "Event.EventEndDatetime converted to DATETIME2 (local time)" },
        { "name": "extEventDescription", "type": "NVARCHAR(4000)", "nullable": false, "description": "COALESCE(Event.FbEventDescription, '') — never NULL" },
        { "name": "eventDescription", "type": "NVARCHAR(4000)", "nullable": false, "description": "COALESCE(Event.EventDescription, '') — never NULL" },
        { "name": "maximumParticipantsAllowed", "type": "SMALLINT", "nullable": true, "description": "Event.MaximumParticipantsAllowed" },
        { "name": "minimumParticipantsRequired", "type": "SMALLINT", "nullable": true, "description": "Event.MinimumParticipantsRequired" },
        { "name": "extLocationOneLineDesc", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.FbLocationOneLineDesc — raw external location one-liner" },
        { "name": "locationOneLineDesc", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.LocationOneLineDesc — HC-managed location one-liner" },
        { "name": "resolvableLocation", "type": "NVARCHAR(MAX)", "nullable": true, "description": "Event.SyncResolvableLocation — geocodeable address string" },
        { "name": "extLocationPostCode", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.FbLocationPostCode" },
        { "name": "extLocationCity", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.FbLocationCity" },
        { "name": "extLocationStreet", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.FbLocationStreet" },
        { "name": "extLocationCountry", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.FbLocationCountry" },
        { "name": "extLocationRegion", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.FbLocationRegion" },
        { "name": "extLocationSubRegion", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.FbLocationSubRegion" },
        { "name": "locationPostCode", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.LocationPostCode" },
        { "name": "locationCity", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.LocationCity" },
        { "name": "locationStreet", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.LocationStreet" },
        { "name": "locationCountry", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.LocationCountry" },
        { "name": "locationRegion", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.LocationRegion" },
        { "name": "locationSubRegion", "type": "NVARCHAR(250)", "nullable": true, "description": "Event.LocationSubRegion" },
        { "name": "removed", "type": "SMALLINT", "nullable": false, "description": "Event.removed — soft-delete flag" },
        { "name": "updatedAt", "type": "DATETIMEOFFSET(7)", "nullable": true, "description": "Event.updatedAt" },
        { "name": "useFbLocation", "type": "SMALLINT", "nullable": true, "description": "Event.UseFbLocation" },
        { "name": "useFbLatLon", "type": "SMALLINT", "nullable": true, "description": "Event.UseFbLatLon" },
        { "name": "useFbRunDetails", "type": "SMALLINT", "nullable": true, "description": "Event.UseFbRunDetails" },
        { "name": "useFbImage", "type": "SMALLINT", "nullable": true, "description": "Event.UseFbImage" },
        { "name": "hcLatitude", "type": "DECIMAL(18,15)", "nullable": true, "description": "Event.Latitude — HC-managed latitude" },
        { "name": "hcLongitude", "type": "DECIMAL(19,15)", "nullable": true, "description": "Event.Longitude — HC-managed longitude" },
        { "name": "fbLatitude", "type": "DECIMAL(18,15)", "nullable": true, "description": "Event.FbLatitude — external (Facebook) latitude" },
        { "name": "fbLongitude", "type": "DECIMAL(19,15)", "nullable": true, "description": "Event.FbLongitude — external (Facebook) longitude" },
        { "name": "countryId", "type": "UNIQUEIDENTIFIER", "nullable": true, "description": "Event.CountryId — country at time of event creation (statistics country, may differ from current kennel country)" },
        { "name": "countryName", "type": "NVARCHAR(250)", "nullable": true, "description": "Country.CountryName from Event.CountryId (c4s alias)" },
        { "name": "kenLatitude", "type": "DECIMAL(18,15)", "nullable": true, "description": "Kennel.Latitude" },
        { "name": "kenLongitude", "type": "DECIMAL(19,15)", "nullable": true, "description": "Kennel.Longitude" },
        { "name": "cityLatitude", "type": "NUMERIC(12,9)", "nullable": true, "description": "City.Latitude — city the kennel is based in" },
        { "name": "cityLongitude", "type": "NUMERIC(13,9)", "nullable": true, "description": "City.Longitude — city the kennel is based in" },
        { "name": "kennelCountryCodes", "type": "NVARCHAR(50)", "nullable": true, "description": "Country.NeighboringCountries from the kennel's country" },
        { "name": "digitsAfterDecimal", "type": "SMALLINT", "nullable": true, "description": "COALESCE(Kennel.DigitsAfterDecimal, Country.DigitsAfterDecimal) — currency decimal places" },
        { "name": "currencySymbol", "type": "NVARCHAR(5)", "nullable": true, "description": "COALESCE(Kennel.CurrencySymbol, Country.CurrencySymbol). Uses '^' as placeholder for the numeric amount in formatted strings." },
        { "name": "searchText", "type": "NVARCHAR(4)", "nullable": false, "description": "Hardcoded empty string — placeholder for future client-side search functionality" }
      ]
    },
    {
      "index": 1,
      "name": "AttendeeListBasic",
      "description": "Returned when caller is NOT a service account (@publicHasherId not in service account GUIDs) AND @includePaymentInfo = 0. One row per attendee. Includes formatted currency strings for payment amounts but no raw payment values.",
      "condition": "(@publicHasherId NOT IN service account GUIDs) AND (@includePaymentInfo = 0)",
      "columns": [
        { "name": "displayName", "type": "NVARCHAR(250)", "nullable": true, "description": "COALESCE(HasherEventMap.DisplayName, Hasher.DisplayName)" },
        { "name": "rsvpState", "type": "SMALLINT", "nullable": true, "description": "HasherEventMap.RsvpState. Known values: 0=no response, 1=maybe, 2+=going." },
        { "name": "attendanceState", "type": "SMALLINT", "nullable": true, "description": "HasherEventMap.AttendenceState. Values >= 20 indicate checked in." },
        { "name": "isHare", "type": "SMALLINT", "nullable": false, "description": "HasherEventMap.IsHare — 1 if this person is a hare for the event, 0 otherwise." },
        { "name": "totalRunsThisKennel", "type": "INT", "nullable": false, "description": "HasherKennelMap.HcTotalRunCount + HasherKennelMap.HistoricalTotalRunCount — current system run count plus legacy imported count. HcTotalRunCount is updated whenever the hasher attends a run, so this is always current regardless of whether the queried event is past or future." },
        { "name": "totalHaringThisKennel", "type": "INT", "nullable": false, "description": "HasherKennelMap.HcHaringCount + HasherKennelMap.HistoricalHaringCount — current system haring count plus legacy imported count." },
        { "name": "amountPaidStr", "type": "NVARCHAR(MAX)", "nullable": false, "description": "COALESCE(formatted currency string using Payment.CreditAmount, '') — '^' in currency symbol replaced with formatted amount" },
        { "name": "amountOwedStr", "type": "NVARCHAR(MAX)", "nullable": false, "description": "COALESCE(formatted currency string using Payment.DebitAmount, '')" },
        { "name": "creditAvailableStr", "type": "NVARCHAR(MAX)", "nullable": false, "description": "COALESCE(formatted currency string using Payment.CreditAvailable, '')" },
        { "name": "virginVisitorType", "type": "SMALLINT", "nullable": true, "description": "HasherEventMap.VirginVisitorType" }
      ]
    },
    {
      "index": 1,
      "name": "AttendeeListWithPayment",
      "description": "Returned when caller is NOT a service account AND @includePaymentInfo = 1. One row per attendee. Includes full payment detail columns in addition to all basic columns.",
      "condition": "(@publicHasherId NOT IN service account GUIDs) AND (@includePaymentInfo = 1)",
      "columns": [
        { "name": "displayName", "type": "NVARCHAR(250)", "nullable": true, "description": "COALESCE(HasherEventMap.DisplayName, Hasher.DisplayName)" },
        { "name": "rsvpState", "type": "SMALLINT", "nullable": true, "description": "HasherEventMap.RsvpState. Known values: 0=no response, 1=maybe, 2+=going." },
        { "name": "attendanceState", "type": "SMALLINT", "nullable": true, "description": "HasherEventMap.AttendenceState. Values >= 20 indicate checked in." },
        { "name": "isHare", "type": "SMALLINT", "nullable": false, "description": "HasherEventMap.IsHare — 1 if this person is a hare for the event, 0 otherwise." },
        { "name": "totalRunsThisKennel", "type": "INT", "nullable": false, "description": "HasherKennelMap.HcTotalRunCount + HasherKennelMap.HistoricalTotalRunCount — current system run count plus legacy imported count. HcTotalRunCount is updated whenever the hasher attends a run, so this is always current regardless of whether the queried event is past or future." },
        { "name": "totalHaringThisKennel", "type": "INT", "nullable": false, "description": "HasherKennelMap.HcHaringCount + HasherKennelMap.HistoricalHaringCount — current system haring count plus legacy imported count." },
        { "name": "virginVisitorType", "type": "SMALLINT", "nullable": true, "description": "HasherEventMap.VirginVisitorType" },
        { "name": "cancelledDate", "type": "DATETIMEOFFSET(7)", "nullable": true, "description": "Payment.CancelledDate" },
        { "name": "cancelledBy", "type": "NVARCHAR(MAX)", "nullable": true, "description": "Hasher.DisplayName of the user who cancelled the payment (computed column)" },
        { "name": "creditAvailable", "type": "SMALLMONEY", "nullable": true, "description": "Payment.CreditAvailable" },
        { "name": "amountPaid", "type": "SMALLMONEY", "nullable": true, "description": "Payment.CreditAmount" },
        { "name": "amountOwed", "type": "SMALLMONEY", "nullable": true, "description": "Payment.DebitAmount" },
        { "name": "netPayment", "type": "SMALLMONEY", "nullable": true, "description": "Payment.NetPayment (computed: CreditAmount - DebitAmount)" },
        { "name": "amountPaidStr", "type": "NVARCHAR(MAX)", "nullable": true, "description": "Formatted currency string with Payment.CreditAmount" },
        { "name": "amountOwedStr", "type": "NVARCHAR(MAX)", "nullable": true, "description": "Formatted currency string with Payment.DebitAmount" },
        { "name": "netPaymentStr", "type": "NVARCHAR(MAX)", "nullable": true, "description": "Formatted currency string with Payment.NetPayment" },
        { "name": "creditAvailableStr", "type": "NVARCHAR(MAX)", "nullable": true, "description": "Formatted currency string with Payment.CreditAvailable" },
        { "name": "doPayForExtras", "type": "SMALLINT", "nullable": true, "description": "Payment.DoPayForExtras" },
        { "name": "paymentConfirmedDate", "type": "DATETIMEOFFSET(7)", "nullable": true, "description": "Payment.ConfirmedDate" },
        { "name": "paymentConfirmedBy", "type": "NVARCHAR(MAX)", "nullable": true, "description": "Hasher.DisplayName of the user who confirmed payment" },
        { "name": "payedDate", "type": "DATETIMEOFFSET(7)", "nullable": true, "description": "Payment.PaidDate" },
        { "name": "paymentType", "type": "SMALLINT", "nullable": true, "description": "Payment.PaymentType (0=Unknown, 1=Not paid, 2=Free, 3=Cash, 4=Bank transfer, 5=Cash other amount, 6=Hash credit, 7=Bank transfer other amount)" },
        { "name": "paymentTypeString", "type": "NVARCHAR(30)", "nullable": true, "description": "Human-readable payment type decoded from Payment.PaymentType via CASE expression" },
        { "name": "paymentReference", "type": "NVARCHAR(50)", "nullable": true, "description": "Payment.PaymentReference" }
      ]
    }
  ],
  "sideEffects": [],
  "breakingChangeRules": [
    "Never remove a column from any rowset",
    "Never rename a parameter",
    "Never change a parameter type",
    "Never change a sentinel value meaning",
    "Never change the precedence order of event lookup methods (publicEventId > runDesignator)",
    "Never change the service account GUID values (11111111-..., 22222222-...) without coordinating with all callers",
    "Never change the @includePaymentInfo=0 vs =1 column sets — callers rely on the split",
    "Never change the 'nextrun'/'lastrun' keyword values without frontend coordination",
    "Never change the 4-hour threshold used in the nextrun/lastrun CTE filter"
  ]
}
