# =============================================================================
# Harrier Central — environment variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.
# =============================================================================

# ── SQL Server (Azure SQL) ────────────────────────────────────────────────────
HC_SQL_SERVER=yourserver.database.windows.net
HC_SQL_DATABASE=HarrierCentral
HC_SQL_USERNAME=yourusername
HC_SQL_PASSWORD=yourpassword

# ── Contract extraction (tools/extract_contracts.js) ─────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
